<h1>Create an account</h1>

<%= form_with model: @user, url: registration_path do |form| %>
  <% if @user.errors.any? %>
    <ul>
      <% @user.errors.full_messages.each do |msg| %>
        <li style="color: red"><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <%= form.label :email_address, "Email" %><br>
  <%= form.email_field :email_address, required: true, autocomplete: "email" %><br>
  <br>
  <%= form.label :password, "Password" %><br>
  <%= form.password_field :password, required: true, autocomplete: "new-password" %><br>
  <br>
  <%= form.label :password_confirmation, "Confirm password" %><br>
  <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %><br>
  <br>
  <%= form.submit "Register" %>
<% end %>

<br>
<%= link_to "Already have an account? Sign in", new_session_path %>
