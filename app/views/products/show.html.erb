<div class="row justify-content-center">
  <div class="col-lg-8">

    <div class="card shadow-sm">
      <% if @product.featured_image.attached? %>
        <%= image_tag @product.featured_image, class: "card-img-top", style: "max-height: 400px; object-fit: cover;" %>
      <% end %>

      <div class="card-body">
        <h1 class="card-title h2 mb-3"><%= @product.name %></h1>

        <% if @product.description.present? %>
          <div class="mb-4">
            <%= @product.description %>
          </div>
        <% end %>

        <p class="text-muted small mb-0">Added <%= @product.created_at.strftime("%B %d, %Y") %></p>
        <p class="text-muted small">Last updated <%= @product.updated_at.strftime("%B %d, %Y") %></p>
      </div>

      <div class="card-footer bg-transparent d-flex gap-2">
        <%= link_to "Edit", edit_product_path(@product), class: "btn btn-outline-secondary" %>
        <%= button_to "Delete", @product, method: :delete,
            class: "btn btn-outline-danger",
            data: { turbo_confirm: "Are you sure?" } %>
        <%= link_to "Back to Products", products_path, class: "btn btn-link text-muted ms-auto" %>
      </div>
    </div>

  </div>
</div>
