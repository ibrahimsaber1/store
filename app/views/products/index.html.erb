<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Products</h1>

    <div id="products">
        <% @products.each do | product | %>
            <div>
            
            <h3> ------- ------- -  </h3>
            <a href="/products/<%= product.id %>"> <%= product.name %> </a>
            <h3> created_at : <%= product.created_at %> </h3>
          </div>
        <%end %>

    </div>
</body>
</html>