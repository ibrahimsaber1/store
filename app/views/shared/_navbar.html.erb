<nav class="navbar navbar-expand-lg bg-dark navbar-dark">
  <div class="container">

    <%= link_to "Books App", root_path, class: "navbar-brand" %>

    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <%= link_to "Products", products_path, class: "nav-link" %>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto">
        <% if authenticated? %>
          <li class="nav-item">
            <span class="nav-link text-light"><%= Current.user.email_address %></span>
          </li>
          <li class="nav-item">
            <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-outline-light btn-sm" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Sign in", new_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Register", new_registration_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>

  </div>
</nav>
